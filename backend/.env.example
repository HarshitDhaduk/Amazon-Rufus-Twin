# ── Required ──────────────────────────────────────────────────────────────────
# Google Gemini — Inference engine (1M context, generous free tier)
# Get FREE key: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Voyage AI — Production embedding model (voyage-3-large, 1024-dim)
# Get FREE key (50M tokens/month): https://www.voyageai.com
# This is Anthropic's own embedding platform — no OpenAI dependency
VOYAGE_API_KEY=your_voyage_api_key_here

# ── Data Extraction (at least one required for real ASIN data) ────────────────
# Primary: Apify Amazon Rufus Scraper (pache/amazon-rufus-scraper)
# Get key: https://apify.com
APIFY_API_TOKEN=your_apify_token_here

# Fallback: Easyparser
# Get key: https://easyparser.io
EASYPARSER_API_KEY=your_easyparser_key_here

# ── Deployment ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
