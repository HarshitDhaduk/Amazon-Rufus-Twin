*.tsbuildinfo
next-env.d.ts

# turbopack / build cache
.turbo/
.swc/

# linting / formatting cache
.eslintcache
.stylelintcache
.prettiercache

# editor
.vscode/
.idea/
*.swp
*.swo
*~
